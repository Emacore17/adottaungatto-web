{
  "name": "adottaungatto-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "db:generate": "pnpm --filter @workspace/db db:generate",
    "db:migrate": "pnpm --filter @workspace/db db:migrate",
    "db:seed": "pnpm --filter @workspace/db db:seed",
    "db:seed:demo": "pnpm --filter @workspace/db db:seed:demo",
    "db:studio": "pnpm --filter @workspace/db db:studio",
    "demo:fresh": "node scripts/local/demo-fresh.mjs",
    "demo:reset": "node scripts/local/demo-reset.mjs",
    "demo:setup": "node scripts/local/demo-setup.mjs",
    "dev": "turbo dev",
    "dev:demo": "node scripts/local/dev-demo.mjs",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up -d",
    "geo:boundaries": "pnpm --filter worker geo:boundaries",
    "geo:boundaries:apply": "pnpm --filter worker geo:boundaries:apply",
    "geo:import": "pnpm --filter worker geo:import",
    "geo:import:apply": "pnpm --filter worker geo:import:apply",
    "geo:promote": "pnpm --filter worker geo:promote",
    "geo:promote:apply": "pnpm --filter worker geo:promote:apply",
    "media:process": "pnpm --filter worker media:process",
    "search:benchmark": "pnpm --filter worker search:benchmark",
    "smoke:e2e": "node scripts/local/e2e-smoke.mjs",
    "lint": "turbo lint",
    "release:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release:smoke": "pnpm db:migrate && pnpm smoke:e2e",
    "format": "turbo format",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
