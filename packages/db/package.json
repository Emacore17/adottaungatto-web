{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:seed:demo": "tsx src/seed-demo.ts",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write \"src/**/*.ts\" \"drizzle.config.ts\"",
    "lint": "eslint .",
    "test": "tsx --test src/seed-demo.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  }
}
