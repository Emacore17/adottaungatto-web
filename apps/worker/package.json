{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:assets": "tsx src/demo/upload-demo-assets.ts",
    "dev": "tsx watch src/main.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "geo:boundaries": "tsx src/geo/import-italian-boundaries-cli.ts --dry-run",
    "geo:boundaries:apply": "tsx src/geo/import-italian-boundaries-cli.ts --apply",
    "geo:import": "tsx src/geo/import-italian-places.ts --dry-run",
    "geo:import:apply": "tsx src/geo/import-italian-places.ts --apply",
    "geo:promote": "tsx src/geo/promote-italian-places-cli.ts --dry-run",
    "geo:promote:apply": "tsx src/geo/promote-italian-places-cli.ts --apply",
    "geo:verify": "tsx src/geo/verify-italian-places-cli.ts",
    "lint": "eslint .",
    "media:process": "tsx src/media/process-listing-images-cli.ts",
    "search:benchmark": "tsx src/search/benchmark-search-cli.ts",
    "start": "node dist/main.js",
    "start:container:dev": "tsx src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "minio": "^8.0.7",
    "sharp": "^0.34.5",
    "shpjs": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
