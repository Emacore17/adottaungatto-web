APP_ENV=production
APP_URL=https://adottaungatto.it
API_URL=https://api.adottaungatto.it
API_INTERNAL_URL=https://api.adottaungatto.it
API_PORT=4000
API_GLOBAL_RATE_LIMIT_PER_MINUTE=1200
API_TRUST_PROXY=true
NEXT_PUBLIC_SITE_URL=https://adottaungatto.it
NEXT_PUBLIC_API_URL=https://api.adottaungatto.it
TRUSTED_ACTION_ORIGINS=https://adottaungatto.it

DATABASE_URL=postgresql://app_user:replace-me@postgres.example.com:5432/adottaungatto
REDIS_URL=redis://redis.example.com:6379

S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_ENDPOINT=https://cdn.adottaungatto.it
NEXT_PUBLIC_S3_PUBLIC_ENDPOINT=https://cdn.adottaungatto.it
S3_REGION=eu-south-1
S3_BUCKET=adottaungatto-prod
NEXT_PUBLIC_S3_BUCKET=adottaungatto-prod
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_FROM=no-reply@adottaungatto.it
EMAIL_VERIFICATION_TTL_MINUTES=60
PASSWORD_RESET_TTL_MINUTES=30
PHONE_VERIFICATION_TTL_MINUTES=10

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LIMIT_MULTIPLIER=1
RATE_LIMIT_WINDOW_MULTIPLIER=1
OBSERVABILITY_ALERT_ERROR_RATE_THRESHOLD=0.05
OBSERVABILITY_ALERT_IN_FLIGHT_THRESHOLD=50
OBSERVABILITY_ALERT_MIN_REQUESTS=20
OBSERVABILITY_ALERT_P95_MS_THRESHOLD=1000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
